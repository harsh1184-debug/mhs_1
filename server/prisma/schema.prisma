generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id           String   @id @default(uuid())
  name         String
  brand        String
  category     String
  description  String
  imageUrls    String
  pdfUrl       String?
  isPublished  Boolean  @default(true)
  rfqs         Rfq[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Rfq {
  id           String   @id @default(uuid())
  clientName   String
  hospitalName String
  email        String
  phone        String
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  status       String   @default("Pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}